# NetGuard AI — Environment Configuration
# =========================================
# Copy this file to .env and fill in your own credentials.
#
#   cp .env.example .env
#
# Then edit .env with your actual values. Never commit .env to git.

# Azure OpenAI — required for the AI Chat feature (/api/ai/chat)
# Get these from: https://portal.azure.com → Azure OpenAI → Your Resource → Keys & Endpoint
AZURE_API_KEY=your-azure-openai-api-key-here
AZURE_API_BASE=https://your-resource-name.openai.azure.com/
AZURE_API_VERSION=2024-10-21
AZURE_DEPLOYMENT_NAME=gpt-4o-mini

# Note: The analytics dashboard (charts, tables, matrix analyzer, CSV upload)
# works fully without any API key. Only the chat widget needs Azure OpenAI.
